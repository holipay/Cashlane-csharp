<UserControl x:Class="Cashlane.Views.StatsCardsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Cashlane.ViewModels">

    <Grid Margin="0,0,0,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Card 1: 本月费用笔数 -->
        <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="12" Padding="20,18" Margin="0,0,6,0">
            <StackPanel Orientation="Horizontal">
                <Border Width="44" Height="44" CornerRadius="7" Background="#E8F4FD">
                    <TextBlock Text="📋" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding MonthCount}" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="本月费用笔数" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Card 2: 本月报销合计 -->
        <Border Grid.Column="1" Background="White" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="12" Padding="20,18" Margin="3,0,3,0">
            <StackPanel Orientation="Horizontal">
                <Border Width="44" Height="44" CornerRadius="7" Background="#DFF6DD">
                    <TextBlock Text="💰" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}">
                        <TextBlock.Text>
                            <Binding Path="MonthReimburse" StringFormat="¥{0:N0}" />
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock Text="本月报销合计" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Card 3: 待审批笔数 -->
        <Border Grid.Column="2" Background="White" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="12" Padding="20,18" Margin="3,0,3,0">
            <StackPanel Orientation="Horizontal">
                <Border Width="44" Height="44" CornerRadius="7" Background="#FFF4CE">
                    <TextBlock Text="⏳" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding PendingCount}" FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="待审批笔数" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Card 4: 预付/代付余额 -->
        <Border Grid.Column="3" Background="White" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="12" Padding="20,18" Margin="6,0,0,0">
            <StackPanel Orientation="Horizontal">
                <Border Width="44" Height="44" CornerRadius="7" Background="#FDE7E9">
                    <TextBlock Text="🏦" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock FontSize="24" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}">
                        <TextBlock.Text>
                            <Binding Path="PrepaidBalance" StringFormat="¥{0:N0}" />
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock Text="预付/代付余额" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

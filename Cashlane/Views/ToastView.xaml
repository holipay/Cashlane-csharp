<Border x:Class="Cashlane.Views.ToastView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Cashlane.Converters"
        Background="#333333"
        CornerRadius="7"
        Padding="18,10"
        Visibility="Collapsed">

    <Border.Effect>
        <DropShadowEffect BlurRadius="16" Opacity="0.12" ShadowDepth="4" />
    </Border.Effect>

    <TextBlock Text="{Binding Message}"
               FontSize="13"
               Foreground="White"
               FontFamily="{StaticResource AppFont}" />
</Border>

<UserControl x:Class="Cashlane.Views.SidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Cashlane.ViewModels">

    <UserControl.Resources>
        <Style x:Key="NavItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextSidebarBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}"
                                Margin="8,1"
                                SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource SidebarHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource SidebarActiveBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextSidebarActiveBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource SidebarBgBrush}" Width="260">
        <DockPanel>
            <!-- Header -->
            <StackPanel DockPanel.Dock="Top" Margin="20,24,20,20">
                <StackPanel Orientation="Horizontal">
                    <Border Width="36" Height="36" CornerRadius="7" Background="{StaticResource AccentBrush}">
                        <TextBlock Text="C" FontSize="18" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Cashlane" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                        <TextBlock Text="费用管理系统 v1.0" FontSize="11" Foreground="#666666" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- Search -->
            <Border DockPanel.Dock="Top" Margin="12,0,12,16">
                <TextBox x:Name="SearchBox" FontSize="13"
                         Padding="10,7"
                         Foreground="#CCCCCC" Background="#2A2A2A"
                         BorderBrush="#444444" BorderThickness="1"
                         />
            </Border>

            <!-- Navigation -->
            <ListBox x:Name="NavList"
                     Background="Transparent"
                     BorderThickness="0"
                     ItemContainerStyle="{StaticResource NavItemStyle}"
                     SelectedValue="{Binding ActivePage, Mode=TwoWay}"
                     SelectedValuePath="Tag">

                <!-- 概览 -->
                <ListBoxItem Tag="dashboard">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊" Width="20" TextAlignment="Center" FontSize="15" />
                        <TextBlock Text="仪表盘" Margin="12,0,0,0" />
                    </StackPanel>
                </ListBoxItem>

                <!-- 业务管理 Section -->
                <ListBoxItem IsHitTestVisible="False" Foreground="#666666" FontSize="11" FontWeight="SemiBold"
                             Padding="12,14,12,6">
                    <TextBlock Text="业务管理" />
                </ListBoxItem>

                <ListBoxItem Tag="expenses">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📋" Width="20" TextAlignment="Center" FontSize="15" />
                        <TextBlock Text="费用录入" Margin="12,0,0,0" />
                        <Border Background="{StaticResource AccentBrush}" CornerRadius="10"
                                Padding="7,1" Margin="8,0,0,0">
                            <TextBlock Text="80" FontSize="11" FontWeight="SemiBold" Foreground="White" />
                        </Border>
                    </StackPanel>
                </ListBoxItem>

                <ListBoxItem Tag="contacts">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="👤" Width="20" TextAlignment="Center" FontSize="15" />
                        <TextBlock Text="联系人" Margin="12,0,0,0" />
                    </StackPanel>
                </ListBoxItem>

                <ListBoxItem Tag="categories">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🏷️" Width="20" TextAlignment="Center" FontSize="15" />
                        <TextBlock Text="科目分类" Margin="12,0,0,0" />
                    </StackPanel>
                </ListBoxItem>

                <!-- 分析 Section -->
                <ListBoxItem IsHitTestVisible="False" Foreground="#666666" FontSize="11" FontWeight="SemiBold"
                             Padding="12,14,12,6">
                    <TextBlock Text="分析" />
                </ListBoxItem>

                <ListBoxItem Tag="reports">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📈" Width="20" TextAlignment="Center" FontSize="15" />
                        <TextBlock Text="报表统计" Margin="12,0,0,0" />
                    </StackPanel>
                </ListBoxItem>

                <!-- 数据 Section -->
                <ListBoxItem IsHitTestVisible="False" Foreground="#666666" FontSize="11" FontWeight="SemiBold"
                             Padding="12,14,12,6">
                    <TextBlock Text="数据" />
                </ListBoxItem>

                <ListBoxItem Tag="import">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📥" Width="20" TextAlignment="Center" FontSize="15" />
                        <TextBlock Text="导入" Margin="12,0,0,0" />
                    </StackPanel>
                </ListBoxItem>

                <ListBoxItem Tag="export">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📤" Width="20" TextAlignment="Center" FontSize="15" />
                        <TextBlock Text="导出" Margin="12,0,0,0" />
                    </StackPanel>
                </ListBoxItem>

                <!-- 系统 Section -->
                <ListBoxItem IsHitTestVisible="False" Foreground="#666666" FontSize="11" FontWeight="SemiBold"
                             Padding="12,14,12,6">
                    <TextBlock Text="系统" />
                </ListBoxItem>

                <ListBoxItem Tag="settings">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙️" Width="20" TextAlignment="Center" FontSize="15" />
                        <TextBlock Text="设置" Margin="12,0,0,0" />
                    </StackPanel>
                </ListBoxItem>
            </ListBox>
        </DockPanel>
    </Border>
</UserControl>

<UserControl x:Class="Cashlane.Views.FilterPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Cashlane.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:StringToDateTimeConverter x:Key="StringToDateTimeConverter" />
        <Style x:Key="FilterLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="FilterInput" TargetType="TextBox">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderBrush" Value="#D1D1D1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        </Style>
        <Style x:Key="FilterCombo" TargetType="ComboBox">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderBrush" Value="#D1D1D1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        </Style>
    </UserControl.Resources>

    <Border Background="White" BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1" CornerRadius="12" Margin="0,0,0,16">
        <DockPanel>
            <!-- Header -->
            <Border DockPanel.Dock="Top"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="20,12"
                    Cursor="Hand"
                    Background="Transparent"
                    MouseLeftButtonDown="TogglePanel">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" Margin="0,0,8,0" />
                        <TextBlock Text="筛选条件" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                    <TextBlock x:Name="ToggleIcon"
                               Text="▼" FontSize="12"
                               Foreground="{StaticResource TextTertiaryBrush}"
                               HorizontalAlignment="Right"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <RotateTransform Angle="180" />
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- Body -->
            <Border x:Name="FilterBody"
                    DockPanel.Dock="Top"
                    Padding="20,16"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <WrapPanel>
                    <!-- 公司 -->
                    <StackPanel Margin="0,0,12,12" MinWidth="160">
                        <TextBlock Text="公司" Style="{StaticResource FilterLabel}" />
                        <ComboBox Style="{StaticResource FilterCombo}"
                                  ItemsSource="{Binding Companies}"
                                  DisplayMemberPath="Name" SelectedValuePath="Id"
                                  SelectedValue="{Binding CompanyId, Mode=TwoWay}" />
                    </StackPanel>

                    <!-- 部门 -->
                    <StackPanel Margin="0,0,12,12" MinWidth="160">
                        <TextBlock Text="部门" Style="{StaticResource FilterLabel}" />
                        <ComboBox Style="{StaticResource FilterCombo}"
                                  ItemsSource="{Binding Departments}"
                                  DisplayMemberPath="Name" SelectedValuePath="Id"
                                  SelectedValue="{Binding DeptId, Mode=TwoWay}" />
                    </StackPanel>

                    <!-- 一级科目 -->
                    <StackPanel Margin="0,0,12,12" MinWidth="160">
                        <TextBlock Text="一级科目" Style="{StaticResource FilterLabel}" />
                        <ComboBox Style="{StaticResource FilterCombo}"
                                  ItemsSource="{Binding Categories}"
                                  DisplayMemberPath="Name" SelectedValuePath="Id"
                                  SelectedValue="{Binding Cat1Id, Mode=TwoWay}" />
                    </StackPanel>

                    <!-- 二级科目 -->
                    <StackPanel Margin="0,0,12,12" MinWidth="160">
                        <TextBlock Text="二级科目" Style="{StaticResource FilterLabel}" />
                        <ComboBox Style="{StaticResource FilterCombo}"
                                  ItemsSource="{Binding Cat2Categories}"
                                  DisplayMemberPath="Name" SelectedValuePath="Id"
                                  SelectedValue="{Binding Cat2Id, Mode=TwoWay}" />
                    </StackPanel>

                    <!-- 报销状态 -->
                    <StackPanel Margin="0,0,12,12" MinWidth="160">
                        <TextBlock Text="报销状态" Style="{StaticResource FilterLabel}" />
                        <ComboBox x:Name="StatusCombo" Style="{StaticResource FilterCombo}"
                                  SelectedValue="{Binding Status, Mode=TwoWay}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Tag="" Content="全部" IsSelected="True" />
                            <ComboBoxItem Tag="填单" Content="填单" />
                            <ComboBoxItem Tag="签录" Content="签录" />
                            <ComboBoxItem Tag="完成" Content="完成" />
                            <ComboBoxItem Tag="取消" Content="取消" />
                            <ComboBoxItem Tag="付款" Content="付款" />
                            <ComboBoxItem Tag="发票" Content="发票" />
                        </ComboBox>
                    </StackPanel>

                    <!-- 方式 -->
                    <StackPanel Margin="0,0,12,12" MinWidth="160">
                        <TextBlock Text="方式" Style="{StaticResource FilterLabel}" />
                        <ComboBox x:Name="MethodCombo" Style="{StaticResource FilterCombo}"
                                  SelectedValue="{Binding Method, Mode=TwoWay}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Tag="" Content="全部" IsSelected="True" />
                            <ComboBoxItem Tag="请款" Content="请款" />
                            <ComboBoxItem Tag="报销" Content="报销" />
                            <ComboBoxItem Tag="其他" Content="其他" />
                        </ComboBox>
                    </StackPanel>

                    <!-- 起始日期 -->
                    <StackPanel Margin="0,0,12,12" MinWidth="160">
                        <TextBlock Text="起始日期" Style="{StaticResource FilterLabel}" />
                        <DatePicker SelectedDate="{Binding DateFrom, Mode=TwoWay, Converter={StaticResource StringToDateTimeConverter}}"
                                    FontSize="13" Height="32" />
                    </StackPanel>

                    <!-- 截止日期 -->
                    <StackPanel Margin="0,0,12,12" MinWidth="160">
                        <TextBlock Text="截止日期" Style="{StaticResource FilterLabel}" />
                        <DatePicker SelectedDate="{Binding DateTo, Mode=TwoWay, Converter={StaticResource StringToDateTimeConverter}}"
                                    FontSize="13" Height="32" />
                    </StackPanel>

                    <!-- 搜索 -->
                    <StackPanel Margin="0,0,12,12" MinWidth="320">
                        <TextBlock Text="搜索" Style="{StaticResource FilterLabel}" />
                        <TextBox Style="{StaticResource FilterInput}"
                                 Text="{Binding Search, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="搜索明细 / 发票内容 / 备注..." />
                    </StackPanel>

                    <!-- Actions -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,12">
                        <Button Content="🔍 查询"
                                Style="{StaticResource SmallPrimaryButton}"
                                Command="{Binding SearchCommand}" />
                        <Button Content="🔄 重置"
                                Style="{StaticResource SmallButton}"
                                Command="{Binding ResetCommand}"
                                Margin="8,0,0,0" />
                    </StackPanel>
                </WrapPanel>
            </Border>
        </DockPanel>
    </Border>
</UserControl>
